# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง (ห้าม commit .env.local)

# ---- Supabase (Settings -> API) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---- Cloudflare Turnstile (กันบอท login/register) ----
# site key = public ใส่ที่นี่ได้ | secret key เอาไปตั้งใน Supabase Auth (CAPTCHA) ห้ามอยู่ใน client
VITE_TURNSTILE_SITE_KEY=YOUR-TURNSTILE-SITE-KEY

# ---- EasySlip (ยืนยันสลิป) ----
# NOTE: token นี้เป็นความลับฝั่ง server ห้ามใส่ในไฟล์ VITE_ (จะหลุดไป client)
# ย้ายไปตั้งใน backend worker แล้ว (backend/.dev.vars หรือ `wrangler secret put EASYSLIP_API_TOKEN`)

# ---- Backend API (Cloudflare Worker แยก - โฟลเดอร์ backend/) ----
# ไม่ตั้ง/เว้นว่าง = ปิด API ใช้ Supabase ตรงแบบเดิม (ไม่มีหน้าบัญชีของฉัน)
# dev  : VITE_API_BASE=/                              (same-origin ผ่าน vite proxy -> localhost:8787)
# prod : VITE_API_BASE=https://<worker>.workers.dev   (ข้ามโดเมน ส่งคุกกี้แบบ SameSite=None)
VITE_API_BASE=/
